.admin {
    display: flex;
    flex-direction: column;
    gap: 22rpx;
    padding: 34rpx;
}

input {
    height: 88rpx;
    box-sizing: border-box;
    padding: 0 28rpx;
    border-radius: 999rpx;
    background: rgba(45, 36, 27, 0.06);
    color: #2d241b;
    font-size: 28rpx;
}

.error {
    color: #9b3d2e;
    font-size: 26rpx;
}
