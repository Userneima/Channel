.task-form {
    display: flex;
    flex-direction: column;
    gap: 22rpx;
    padding: 34rpx;
}

textarea {
    width: 100%;
    min-height: 260rpx;
    box-sizing: border-box;
    padding: 26rpx;
    border-radius: 26rpx;
    background: rgba(45, 36, 27, 0.06);
    color: #2d241b;
    font-size: 28rpx;
    line-height: 1.6;
}

.picker {
    padding: 28rpx;
    border-radius: 24rpx;
    background: rgba(45, 36, 27, 0.06);
    color: #2d241b;
    font-size: 28rpx;
}

.error {
    color: #9b3d2e;
    font-size: 26rpx;
}
